---
import BaseLayout from './BaseLayout.astro';
import { CATEGORIES, type CategoryKey } from '../consts';
import { formatDate } from '../utils/date';

interface Props {
  title: string;
  description?: string;
  pubDatetime: Date;
  modDatetime?: Date;
  category: CategoryKey;
  tags: string[];
  source?: string;
  cover?: string;
  readingTime: string;
}

const {
  title,
  description,
  pubDatetime,
  modDatetime,
  category,
  tags,
  source,
  readingTime,
} = Astro.props;

const categoryInfo = CATEGORIES[category];
const formattedDate = formatDate(pubDatetime);
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <header class="post-header">
      <a
        href={`/categories/${category}`}
        class="category-badge"
        style={`color: ${categoryInfo.color}; border-color: ${categoryInfo.color};`}
      >
        {categoryInfo.label}
      </a>
      <h1 class="post-title">{title}</h1>
      {description && <p class="post-desc">{description}</p>}
      <div class="post-meta">
        <time datetime={pubDatetime.toISOString()}>{formattedDate}</time>
        <span>·</span>
        <span>{readingTime}</span>
        {source && (
          <>
            <span>·</span>
            <span class="source">同步自 {source}</span>
          </>
        )}
      </div>
      {modDatetime && (
        <p class="post-meta mod muted">
          最后更新于 {formatDate(modDatetime)}
        </p>
      )}
    </header>

    <div class="prose post-content">
      <slot />
    </div>

    {tags.length > 0 && (
      <footer class="post-footer">
        {tags.map((tag) => (
          <span class="tag">#{tag}</span>
        ))}
      </footer>
    )}

    <nav class="post-nav muted">
      <a href="/">← 返回首页</a>
      <a href={`/categories/${category}`}>查看更多「{categoryInfo.label}」→</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 3em;
    padding-bottom: 1.5em;
    border-bottom: 1px solid var(--border);
  }
  .category-badge {
    display: inline-block;
    font-size: 0.85em;
    padding: 2px 10px;
    border: 1px solid;
    border-radius: 3px;
    margin-bottom: 1em;
    border-bottom: 1px solid !important;
  }
  .post-title {
    margin: 0 0 0.4em;
    font-size: 2rem;
    line-height: 1.3;
  }
  .post-desc {
    color: var(--text-soft);
    font-size: 1.1rem;
    margin: 0.5em 0;
  }
  .post-meta {
    display: flex;
    gap: 0.5em;
    flex-wrap: wrap;
    font-size: 0.9em;
    color: var(--text-mute);
    margin-top: 1em;
  }
  .post-meta.mod {
    margin-top: 0.5em;
    font-size: 0.85em;
  }
  .source {
    font-style: italic;
  }
  .post-content :global(img) {
    margin: 1.5em auto;
    display: block;
  }
  .post-footer {
    margin-top: 3em;
    padding-top: 2em;
    border-top: 1px solid var(--border);
  }
  .post-nav {
    margin-top: 3em;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1em;
  }
  @media (max-width: 640px) {
    .post-title { font-size: 1.6rem; }
  }
</style>