---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, SITE } from '../consts';
import { formatDateShort } from '../utils/date';

// 获取所有文章（草稿排除），按发布时间倒序
const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDatetime.getTime() - a.data.pubDatetime.getTime());

const recent = posts.slice(0, 8);
---

<BaseLayout>
  <section class="intro">
    <h1>{SITE.title}</h1>
    <p class="muted">{SITE.description}</p>
  </section>

  <section class="categories">
    <h2>分类</h2>
    <ul class="category-grid">
      {Object.entries(CATEGORIES).map(([key, cat]) => {
        const count = posts.filter((p) => p.data.category === key).length;
        return (
          <li>
            <a href={`/categories/${key}`} class="category-card">
              <span class="cat-label" style={`color: ${cat.color};`}>{cat.label}</span>
              <span class="cat-count muted">{count} 篇</span>
              <span class="cat-desc muted">{cat.desc}</span>
            </a>
          </li>
        );
      })}
    </ul>
  </section>

  <section class="recent">
    <h2>最新文章</h2>
    {recent.length === 0 ? (
      <p class="muted">还没有文章。<a href="/admin-guide">看看怎么发布第一篇</a>。</p>
    ) : (
      <ul class="post-list">
        {recent.map((post) => {
          const cat = CATEGORIES[post.data.category];
          return (
            <li class="post-item">
              <a href={`/posts/${post.id}`} class="post-link">
                <div class="post-row">
                  <h3 class="post-title-sm">{post.data.title}</h3>
                  <time class="post-date muted">{formatDateShort(post.data.pubDatetime)}</time>
                </div>
                {post.data.description && (
                  <p class="post-desc-sm muted">{post.data.description}</p>
                )}
                <span class="cat-tag" style={`color: ${cat.color};`}>
                  {cat.label}
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    )}
    {posts.length > 8 && (
      <p class="more">
        <a href="/archive">查看全部 {posts.length} 篇文章 →</a>
      </p>
    )}
  </section>
</BaseLayout>

<style>
  .intro {
    margin-bottom: 3em;
  }
  .intro h1 {
    font-size: 2rem;
    margin: 0 0 0.3em;
  }
  .intro p {
    margin: 0;
    font-size: 1.05rem;
  }
  h2 {
    font-size: 1.3rem;
    margin: 2.5em 0 1em;
    padding-bottom: 0.4em;
    border-bottom: 1px solid var(--border);
  }
  .category-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1em;
  }
  .category-card {
    display: flex;
    flex-direction: column;
    padding: 1.2em;
    border: 1px solid var(--border);
    border-radius: 6px;
    border-bottom: 1px solid var(--border) !important;
    transition: border-color 0.15s, transform 0.15s;
  }
  .category-card:hover {
    border-color: var(--text-mute);
    transform: translateY(-1px);
  }
  .cat-label {
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 0.3em;
  }
  .cat-count {
    font-size: 0.85em;
    margin-bottom: 0.5em;
  }
  .cat-desc {
    font-size: 0.9em;
  }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .post-item {
    border-bottom: 1px solid var(--border);
  }
  .post-item:last-child {
    border-bottom: none;
  }
  .post-link {
    display: block;
    padding: 1.4em 0;
    border-bottom: none !important;
  }
  .post-link:hover .post-title-sm {
    color: var(--accent);
  }
  .post-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1em;
    margin-bottom: 0.4em;
  }
  .post-title-sm {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
    transition: color 0.15s;
  }
  .post-date {
    font-size: 0.85em;
    white-space: nowrap;
  }
  .post-desc-sm {
    margin: 0 0 0.5em;
    font-size: 0.95em;
  }
  .cat-tag {
    font-size: 0.85em;
    font-weight: 500;
  }
  .more {
    margin-top: 2em;
    text-align: center;
  }
  @media (max-width: 640px) {
    .post-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2em;
    }
  }
</style>